# Get your API key from https://console.mistral.ai/
MISTRAL_API_KEY=your_mistral_api_key_here

# Mistral model for chat (mistral-small-latest is free-tier friendly)
MISTRAL_MODEL=mistral-small-latest

# Path to the folder containing your Bildungsplan PDFs
PDF_FOLDER=./Bildungsplan_PDFs

# Path where the ChromaDB vector database will be stored
CHROMA_DB_PATH=./chroma_db

# Number of relevant chunks to retrieve per query
TOP_K=8

# Minimum cosine similarity score for a chunk to be considered relevant.
# Below this, the assistant falls back to web search instead.
# Calibrated for mistral-embed + this document collection (off-topic ~0.75, on-topic ~0.83)
MIN_RELEVANCE_SCORE=0.79

# Server settings
PORT=5001
HOST=127.0.0.1

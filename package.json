{
  "name": "eulenai-teacher-tools",
  "version": "1.0.0",
  "private": true,
  "description": "EulenAI – KI-Werkzeuge für Lehrkräfte an SBBZ",
  "scripts": {
    "start": "node server.js",
    "start:bildungsplan": "cd bildungsplan && node server.js",
    "start:leichte": "cd leichte-sprache && node server.js",
    "start:all": "node server.js & cd bildungsplan && node server.js & cd leichte-sprache && node server.js",
    "deploy": "./deploy.sh",
    "ingest": "cd bildungsplan && python3 ingest.py"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "chromadb": "^1.9.2",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-session": "^1.19.0",
    "http-proxy-middleware": "^3.0.5",
    "node-fetch": "^2.6.7",
    "session-file-store": "^1.5.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  }
}
